{
  "name": "omx_ros2",
  "image": "osrf/ros:humble-desktop",
  "remoteUser": "root",

  "workspaceFolder": "/workspaces/omx_ros2",
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspaces/omx_ros2,type=bind,consistency=cached",

  "shutdownAction": "stopContainer",

  "containerEnv": {
    "ROS_DISTRO": "humble"
  },

  "postCreateCommand": "chmod +x /workspaces/omx_ros2/.devcontainer/setup.sh && /workspaces/omx_ros2/.devcontainer/setup.sh",
  
  "runArgs": [
  "--privileged",
  "--device=/dev/ttyUSB0",
  "--device=/dev/ttyACM0",
  "--volume=/dev/serial:/dev/serial",
  "--memory=20g",
  "--memory-swap=28g",
  "--cpus=6",
  "--shm-size=8g"
],
  "runArgs": [
    "--privileged",
    "--device=/dev/ttyUSB0",
    "--device=/dev/ttyACM0",
    "--volume=/dev/serial:/dev/serial",
    "--memory=20g",
    "--memory-swap=28g",
    "--cpus=6",
    "--shm-size=8g",
    "--volume=/mnt/wslg:/mnt/wslg",
    "--volume=/tmp/.X11-unix:/tmp/.X11-unix",
    "--env=DISPLAY",
    "--env=WAYLAND_DISPLAY",
    "--env=XDG_RUNTIME_DIR",
    "--env=PULSE_SERVER"
  ],
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-iot.vscode-ros",
        "ms-vscode.cpptools",
        "ms-python.python"
      ]
    }
  }
  ,
  "remoteEnv": {
    "DISPLAY": "${localEnv:DISPLAY}",
    "WAYLAND_DISPLAY": "${localEnv:WAYLAND_DISPLAY}",
    "XDG_RUNTIME_DIR": "${localEnv:XDG_RUNTIME_DIR}",
    "PULSE_SERVER": "${localEnv:PULSE_SERVER}"
  }
}
